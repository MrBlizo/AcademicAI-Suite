<Window x:Class="AcademicAI.App.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AcademicAI Suite"
        Width="520" Height="300"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">
    <Border CornerRadius="16" Background="{DynamicResource ApplicationBackgroundBrush}"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.35" Color="Black" />
        </Border.Effect>
        <Grid>
            <!-- Gradient accent bar across the top -->
            <Border CornerRadius="16,16,0,0" Height="4" VerticalAlignment="Top">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#6366F1" Offset="0" />
                        <GradientStop Color="#8B5CF6" Offset="0.5" />
                        <GradientStop Color="#A78BFA" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="48,40,48,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Title with accent color -->
                <TextBlock Grid.Row="0" Text="AcademicAI Suite" FontSize="28" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />

                <!-- Subtitle -->
                <TextBlock Grid.Row="2" Text="Your AI-powered academic companion"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <!-- Version -->
                <TextBlock x:Name="VersionText" Grid.Row="4" FontSize="11"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                <!-- Progress Bar -->
                <ProgressBar x:Name="ProgressBar" Grid.Row="6" Value="0" IsIndeterminate="False"
                             Height="4" />

                <!-- Status Text -->
                <TextBlock x:Name="StatusText" Grid.Row="8" Text="Initializing..."
                           FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </Grid>
        </Grid>
    </Border>
</Window>
