<UserControl x:Class="AcademicAI.App.Views.AcademicWriterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:AcademicAI.App.Controls">
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Compose Panel -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Page Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <ui:SymbolIcon Symbol="DocumentEdit24" FontSize="24"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   Margin="0,0,10,0" VerticalAlignment="Center" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Title_AcademicWriter}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{DynamicResource Desc_AcademicWriter}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <ui:Card Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="3" CornerRadius="2"
                                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    Margin="0,0,10,0" />
                            <TextBlock Text="{DynamicResource Lbl_Input}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Lbl_Topic}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ui:TextBox x:Name="PromptBox"
                                    PlaceholderText="Describe what you want to write..."
                                    Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                    AcceptsReturn="True" TextWrapping="Wrap"
                                    MinHeight="120"
                                    VerticalScrollBarVisibility="Auto"
                                    Margin="0,0,0,4"
                                    TextChanged="PromptBox_TextChanged" />
                        <TextBlock x:Name="PromptCountLabel" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Right" Margin="0,0,0,16" />

                        <TextBlock Text="{DynamicResource Lbl_WritingType}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding AvailableTypes}"
                                  SelectedItem="{Binding SelectedType}"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Lbl_Tone}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding AvailableTones}"
                                  SelectedItem="{Binding SelectedTone}"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Lbl_Length}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ComboBox SelectedIndex="1" Margin="0,0,0,20">
                            <ComboBoxItem Content="{DynamicResource Length_Short}" />
                            <ComboBoxItem Content="{DynamicResource Length_Medium}" />
                            <ComboBoxItem Content="{DynamicResource Length_Long}" />
                            <ComboBoxItem Content="{DynamicResource Length_Extended}" />
                        </ComboBox>

                        <ui:Button Appearance="Primary"
                                   Command="{Binding GenerateCommand}"
                                   IsEnabled="{Binding IsGenerating, Converter={StaticResource BoolNegate}}"
                                   HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Bot24" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Btn_Generate}" />
                            </StackPanel>
                        </ui:Button>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"
                                    Margin="0,10,0,0">
                            <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0" />
                            <TextBlock Text="{DynamicResource Msg_Generating}" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT: Output Panel -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Error -->
                <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                           Margin="0,0,0,8"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />

                <ui:Card Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="3" CornerRadius="2"
                                    Background="{DynamicResource SystemFillColorSuccessBrush}"
                                    Margin="0,0,10,0" />
                            <ui:SymbolIcon Symbol="DocumentText24" FontSize="18"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,8,0" />
                            <TextBlock Text="{DynamicResource Lbl_Output}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <controls:MarkdownViewer MarkdownText="{Binding GeneratedText}" />

                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Right">
                            <ui:Button Appearance="Secondary" Command="{Binding CopyResultCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Copy24" Margin="0,0,6,0" />
                                    <TextBlock Text="{DynamicResource Btn_Copy}" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Appearance="Primary" Command="{Binding SaveResultCommand}"
                                       Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Save24" Margin="0,0,6,0" />
                                    <TextBlock Text="{DynamicResource Btn_Save}" />
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
