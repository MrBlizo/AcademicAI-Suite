<Page x:Class="AcademicAI.App.Views.HumanizerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Humanizer">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28">

            <!-- Page Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="People24" FontSize="28"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="AI Humanizer" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Transform AI-generated text into natural, human-sounding academic writing"
                               FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Input Card -->
            <ui:Card Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2"
                                Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="Input" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="PASTE AI-GENERATED TEXT" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6" />
                    <ui:TextBox x:Name="InputBox"
                                PlaceholderText="Paste AI-generated text to humanize..."
                                Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True" TextWrapping="Wrap"
                                MinHeight="160"
                                VerticalScrollBarVisibility="Auto"
                                Margin="0,0,0,6"
                                TextChanged="InputBox_TextChanged" />

                    <!-- Live word / char count -->
                    <TextBlock x:Name="InputCountLabel" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Right" Margin="0,0,0,16" />

                    <!-- Controls row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TONE" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding AvailableTones}"
                                      SelectedItem="{Binding SelectedTone}" MinWidth="140" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="STRENGTH" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <Slider x:Name="StrengthSlider" Minimum="1" Maximum="5" Value="3"
                                        Width="120" VerticalAlignment="Center"
                                        IsSnapToTickEnabled="True" TickFrequency="1" />
                                <TextBlock Text="{Binding ElementName=StrengthSlider, Path=Value, StringFormat='  {0}/5'}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Action row -->
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Appearance="Primary"
                                   Command="{Binding HumanizeCommand}"
                                   IsEnabled="{Binding IsHumanizing, Converter={StaticResource BoolNegate}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="People24" Margin="0,0,8,0" />
                                <TextBlock Text="Humanize" />
                            </StackPanel>
                        </ui:Button>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsHumanizing, Converter={StaticResource BoolToVis}}"
                                    Margin="16,0,0,0">
                            <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0" />
                            <TextBlock Text="Humanizing..." FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       Margin="0,0,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />

            <!-- Result Card -->
            <ui:Card Padding="24" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2"
                                Background="{DynamicResource SystemFillColorSuccessBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="Humanized Text" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <TextBox Text="{Binding HumanizedText, Mode=OneWay}"
                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 FontSize="13" />
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="OutputCountLabel" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ui:Button Appearance="Secondary" Command="{Binding CopyResultCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Copy24" Margin="0,0,6,0" />
                                <TextBlock Text="Copy" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
