<Page x:Class="AcademicAI.App.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Dashboard">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28">

            <!-- WELCOME CARD -->
            <Border Margin="0,0,0,20" CornerRadius="12" Padding="28">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.6">
                        <GradientStop Color="#1A6366F1" Offset="0" />
                        <GradientStop Color="#0D8B5CF6" Offset="0.5" />
                        <GradientStop Color="#0014B8A6" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Greeting}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="What would you like to work on today?"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <ui:SymbolIcon Grid.Column="1" Symbol="HatGraduation24" FontSize="52"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" Opacity="0.3" />
                </Grid>
            </Border>

            <!-- STATS ROW -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Study Mastery -->
                <ui:Card Grid.Column="0" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="6"
                                    Background="#266366F1"
                                    Margin="0,0,10,0">
                                <ui:SymbolIcon Symbol="HatGraduation24" FontSize="16"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Study Mastery" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding StudyMasteryPercent, StringFormat='{}{0:F0}%'}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <ProgressBar Value="{Binding StudyMasteryPercent, Mode=OneWay}"
                                     Maximum="100" Margin="0,8,0,0" Height="4" />
                    </StackPanel>
                </ui:Card>

                <!-- AI Usage -->
                <ui:Card Grid.Column="2" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="6"
                                    Background="#2610B981"
                                    Margin="0,0,10,0">
                                <ui:SymbolIcon Symbol="Bot24" FontSize="16"
                                               Foreground="#10B981"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="AI Calls" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding AiUsageCalls}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{Binding AiUsageTokens, StringFormat='{}{0:N0} tokens'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </ui:Card>

                <!-- Deadlines -->
                <ui:Card Grid.Column="4" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="28" Height="28" CornerRadius="6"
                                    Background="#26F87171"
                                    Margin="0,0,10,0">
                                <ui:SymbolIcon Symbol="CalendarMonth24" FontSize="16"
                                               Foreground="#F87171"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Upcoming" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding UpcomingDeadlines}"
                                      MaxHeight="80">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="12"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Margin="0,0,0,2">
                                        <Run Text="{Binding Title}" FontWeight="SemiBold" />
                                        <Run Text="  " />
                                        <Run Text="{Binding DueDate, StringFormat='{}{0:MMM dd}'}"
                                             Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- TWO COLUMN: Pomodoro + Goals -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- POMODORO CARD -->
                <ui:Card Grid.Column="0" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="3" CornerRadius="2"
                                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    Margin="0,0,10,0" />
                            <ui:SymbolIcon Symbol="Clock24" FontSize="20"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,8,0" />
                            <TextBlock Text="Pomodoro Timer" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{Binding TimerDisplay}"
                                   FontSize="48" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8" />

                        <TextBlock Text="{Binding CompletedSessions, StringFormat='{}{0} sessions completed'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6" />

                        <!-- Focus / Break indicator — NO EMOJI -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Target24" FontSize="14"
                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                           Margin="0,0,4,0"
                                           Visibility="{Binding IsBreak, Converter={StaticResource InvertBoolToVis}}" />
                            <TextBlock Text="Focus" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                       Visibility="{Binding IsBreak, Converter={StaticResource InvertBoolToVis}}" />
                            <ui:SymbolIcon Symbol="DrinkCoffee24" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,4,0"
                                           Visibility="{Binding IsBreak, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="Break" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Visibility="{Binding IsBreak, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <ui:Button Content="Start" Appearance="Primary"
                                       Command="{Binding StartTimerCommand}" />
                            <ui:Button Content="Pause" Appearance="Secondary"
                                       Command="{Binding PauseTimerCommand}" Margin="8,0,0,0" />
                            <ui:Button Content="Skip" Appearance="Secondary"
                                       Command="{Binding SkipTimerCommand}" Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <!-- GOALS CARD -->
                <ui:Card Grid.Column="2" Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="3" CornerRadius="2"
                                    Background="{DynamicResource SystemFillColorSuccessBrush}"
                                    Margin="0,0,10,0" />
                            <ui:SymbolIcon Symbol="Target24" FontSize="20"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,8,0" />
                            <TextBlock Text="Goals" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Add goal form -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" PlaceholderText="Goal title..."
                                        Text="{Binding NewGoalTitle}" Margin="0,0,4,0" />
                            <ui:TextBox Grid.Column="1" PlaceholderText="Target"
                                        Text="{Binding NewGoalTarget}" Margin="0,0,4,0" />
                            <ui:TextBox Grid.Column="2" PlaceholderText="Unit"
                                        Text="{Binding NewGoalUnit}" Margin="0,0,4,0" />
                            <ComboBox Grid.Column="3" SelectedValue="{Binding NewGoalCategory}"
                                      SelectedValuePath="Content" Margin="0,0,4,0"
                                      VerticalAlignment="Center">
                                <ComboBoxItem Content="Study" />
                                <ComboBoxItem Content="Fitness" />
                                <ComboBoxItem Content="Reading" />
                                <ComboBoxItem Content="Project" />
                                <ComboBoxItem Content="Personal" />
                            </ComboBox>
                            <ui:Button Grid.Column="4" Content="Add" Appearance="Primary"
                                       Command="{Binding AddGoalCommand}" />
                        </Grid>

                        <!-- Goals list -->
                        <ItemsControl ItemsSource="{Binding Goals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <ProgressBar Value="{Binding CurrentValue}"
                                                         Maximum="{Binding TargetValue}"
                                                         Margin="0,4,0,0" Height="4" />
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                <Run Text="{Binding CurrentValue}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding TargetValue}" />
                                                <Run Text=" " />
                                                <Run Text="{Binding Unit}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" Content="+"
                                                   Appearance="Transparent"
                                                   Command="{Binding DataContext.IncrementGoalCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}" Margin="4,0,0,0" />
                                        <ui:Button Grid.Column="2" Appearance="Transparent"
                                                   Command="{Binding DataContext.DeleteGoalCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}" Margin="4,0,0,0">
                                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" />
                                        </ui:Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- QUICK ACTIONS -->
            <StackPanel Visibility="{Binding ShowQuickActions, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="3" CornerRadius="2"
                            Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            Margin="0,0,10,0" />
                    <TextBlock Text="Quick Actions" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:Card Grid.Column="0" Padding="20" Cursor="Hand"
                             MouseLeftButtonDown="NavigateToWriter">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="44" Height="44" CornerRadius="10"
                                    Background="#266366F1"
                                    HorizontalAlignment="Center" Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="DocumentEdit24" FontSize="22"
                                               Foreground="#818CF8"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Write" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Column="2" Padding="20" Cursor="Hand"
                             MouseLeftButtonDown="NavigateToTranslator">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="44" Height="44" CornerRadius="10"
                                    Background="#2610B981"
                                    HorizontalAlignment="Center" Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="Translate24" FontSize="22"
                                               Foreground="#34D399"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Translate" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Column="4" Padding="20" Cursor="Hand"
                             MouseLeftButtonDown="NavigateToSummarizer">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="44" Height="44" CornerRadius="10"
                                    Background="#26F59E0B"
                                    HorizontalAlignment="Center" Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="DocumentText24" FontSize="22"
                                               Foreground="#FBBF24"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Summarize" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Column="6" Padding="20" Cursor="Hand"
                             MouseLeftButtonDown="NavigateToDetector">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="44" Height="44" CornerRadius="10"
                                    Background="#26EC4899"
                                    HorizontalAlignment="Center" Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="22"
                                               Foreground="#F472B6"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Detect AI" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </ui:Card>
                </Grid>
            </StackPanel>

            <!-- Study Streak -->
            <ui:Card Padding="20" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="10"
                            Background="#2610B981"
                            Margin="0,0,16,0">
                        <ui:SymbolIcon Symbol="Trophy24" FontSize="22"
                                       Foreground="#34D399"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Study Streak" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding StreakText}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
