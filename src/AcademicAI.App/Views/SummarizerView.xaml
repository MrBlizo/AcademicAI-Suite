<UserControl x:Class="AcademicAI.App.Views.SummarizerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:AcademicAI.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28">

            <!-- Page Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="DocumentText24" FontSize="28"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Title_Summarizer}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="{DynamicResource Desc_Summarizer}"
                               FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Input Card -->
            <ui:Card Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2"
                                Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="{DynamicResource Lbl_Input}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{DynamicResource Lbl_PdfInput}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,6" />
                    <controls:PdfDropZone x:Name="PdfDrop" Height="80" Margin="0,0,0,12" />

                    <TextBlock Text="{DynamicResource Msg_OrPasteBelow}" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,10" />

                    <ui:TextBox x:Name="InputBox"
                                PlaceholderText="Paste text to summarize..."
                                Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True" TextWrapping="Wrap"
                                MinHeight="110"
                                VerticalScrollBarVisibility="Auto"
                                Margin="0,0,0,4"
                                TextChanged="InputBox_TextChanged" />
                    <TextBlock x:Name="InputCountLabel" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Right" Margin="0,0,0,16" />

                    <!-- Summary length + action -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource Lbl_SummaryLength}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6" />
                            <ComboBox MinWidth="160" SelectedIndex="1">
                                <ComboBoxItem Content="{DynamicResource SummaryLength_Brief}" />
                                <ComboBoxItem Content="{DynamicResource SummaryLength_Detailed}" />
                                <ComboBoxItem Content="{DynamicResource SummaryLength_BulletPoints}" />
                                <ComboBoxItem Content="{DynamicResource SummaryLength_Executive}" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                            <ui:Button Appearance="Primary"
                                       Command="{Binding SummarizeCommand}"
                                       IsEnabled="{Binding IsSummarizing, Converter={StaticResource BoolNegate}}"
                                       HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="DocumentText24" Margin="0,0,8,0" />
                                    <TextBlock Text="{DynamicResource Btn_Summarize}" />
                                </StackPanel>
                            </ui:Button>
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsSummarizing, Converter={StaticResource BoolToVis}}"
                                        Margin="0,8,0,0">
                                <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Msg_Generating}" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       Margin="0,0,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />

            <!-- Result Card -->
            <ui:Card Padding="24" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2"
                                Background="{DynamicResource SystemFillColorSuccessBrush}"
                                Margin="0,0,10,0" />
                        <ui:SymbolIcon Symbol="CardUi24" FontSize="18"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,8,0" />
                        <TextBlock Text="{DynamicResource Lbl_Output}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <TextBox Text="{Binding SummaryText, Mode=OneWay}"
                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="120" Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 FontSize="13" />
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="OutputCountLabel" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ui:Button Appearance="Secondary" Command="{Binding CopyResultCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Copy24" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource Btn_Copy}" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
