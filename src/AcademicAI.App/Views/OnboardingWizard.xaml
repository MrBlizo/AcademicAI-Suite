<Window x:Class="AcademicAI.App.Views.OnboardingWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Welcome to AcademicAI Suite"
        Width="560" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <ui:SymbolIcon Symbol="HatGraduation24" FontSize="28"
                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                           Margin="0,0,12,0" VerticalAlignment="Center" />
            <TextBlock x:Name="TitleText" Text="{DynamicResource Title_OnboardingWelcome}" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock x:Name="SubtitleText" Grid.Row="2"
                   Text="{DynamicResource Desc_OnboardingSubtitle}"
                   FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <!-- Step Indicator -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Border x:Name="Step1Circle" Width="32" Height="32" CornerRadius="16"
                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}">
                <TextBlock Text="1" FontSize="14" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border x:Name="StepLine1" Width="40" Height="2" VerticalAlignment="Center"
                    Background="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Border x:Name="Step2Circle" Width="32" Height="32" CornerRadius="16"
                    Background="{DynamicResource ControlStrokeColorDefaultBrush}">
                <TextBlock Text="2" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border x:Name="StepLine2" Width="40" Height="2" VerticalAlignment="Center"
                    Background="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Border x:Name="Step3Circle" Width="32" Height="32" CornerRadius="16"
                    Background="{DynamicResource ControlStrokeColorDefaultBrush}">
                <TextBlock Text="3" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
        </StackPanel>

        <!-- Step Content -->
        <Grid Grid.Row="6">
            <!-- Step 1: Language -->
            <StackPanel x:Name="Step1Content">
                <TextBlock Text="{DynamicResource Lbl_ChooseLanguage}" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,16" />
                <ComboBox x:Name="LanguageCombo" FontSize="14"
                          SelectionChanged="LanguageCombo_SelectionChanged" />
                <TextBlock Text="{DynamicResource Msg_ChangeInSettings}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,12,0,0" />
            </StackPanel>

            <!-- Step 2: AI Provider -->
            <StackPanel x:Name="Step2Content" Visibility="Collapsed">
                <TextBlock Text="{DynamicResource Lbl_SelectProvider}" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,16" />
                <ComboBox x:Name="ProviderCombo" FontSize="14"
                          SelectionChanged="ProviderCombo_SelectionChanged" Margin="0,0,0,16" />

                <TextBlock Text="{DynamicResource Lbl_SelectModel}" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8" />
                <ComboBox x:Name="ModelCombo" FontSize="14" />

                <TextBlock x:Name="ProviderHint" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,16,0,0"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{DynamicResource Msg_GetApiKey_OpenRouter}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ProviderCombo, Path=SelectedItem}" Value="Fireworks">
                                    <Setter Property="Text" Value="{DynamicResource Msg_GetApiKey_Fireworks}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- Step 3: API Key -->
            <StackPanel x:Name="Step3Content" Visibility="Collapsed">
                <TextBlock Text="{DynamicResource Lbl_EnterApiKey}" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,16" />
                <ui:PasswordBox x:Name="ApiKeyBox" PlaceholderText="Enter your API key..." Margin="0,0,0,16" />
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="{DynamicResource Msg_ApiKeySecurity}" />
            </StackPanel>
        </Grid>

        <!-- Navigation Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button x:Name="BackBtn" Content="{DynamicResource Btn_Back}" Appearance="Secondary"
                       Click="BackBtn_Click" Visibility="Collapsed" Margin="0,0,8,0" />
            <ui:Button x:Name="SkipBtn" Content="{DynamicResource Btn_Skip}" Appearance="Secondary"
                       Click="SkipBtn_Click" Margin="0,0,8,0" />
            <ui:Button x:Name="NextBtn" Appearance="Primary" Click="NextBtn_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="NextBtnText" Text="{DynamicResource Btn_Next}" />
                    <ui:SymbolIcon Symbol="ArrowRight24" Margin="6,0,0,0" />
                </StackPanel>
            </ui:Button>
        </StackPanel>
    </Grid>
</Window>
