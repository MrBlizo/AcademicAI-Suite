<Window x:Class="AcademicAI.App.Views.OnboardingWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Welcome to AcademicAI Suite"
        Width="560" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 0: Title -->
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />   <!-- 2: Subtitle -->
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />   <!-- 4: Step indicator -->
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />   <!-- 6: Language label -->
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />   <!-- 8: Language combo -->
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />   <!-- 10: Provider label -->
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />   <!-- 12: Provider combo -->
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />   <!-- 14: Model label -->
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />   <!-- 16: Model combo -->
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />   <!-- 18: API key fields -->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />   <!-- 20: Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <ui:SymbolIcon Symbol="HatGraduation24" FontSize="28"
                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                           Margin="0,0,12,0" VerticalAlignment="Center" />
            <TextBlock Text="Welcome to AcademicAI Suite" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Set up your language and AI provider to get started."
                   FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <!-- Step Indicator -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Border Width="32" Height="32" CornerRadius="16"
                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}">
                <TextBlock Text="1" FontSize="14" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Width="40" Height="2" VerticalAlignment="Center"
                    Background="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Border Width="32" Height="32" CornerRadius="16"
                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}">
                <TextBlock Text="2" FontSize="14" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Width="40" Height="2" VerticalAlignment="Center"
                    Background="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Border Width="32" Height="32" CornerRadius="16"
                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}">
                <TextBlock Text="3" FontSize="14" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
        </StackPanel>

        <!-- Language -->
        <StackPanel Grid.Row="6" Orientation="Horizontal">
            <Border Width="3" CornerRadius="2"
                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                    Margin="0,0,8,0" />
            <TextBlock Text="Language" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </StackPanel>
        <ComboBox x:Name="LanguageCombo" Grid.Row="8"
                  SelectionChanged="LanguageCombo_SelectionChanged" />

        <!-- AI Provider -->
        <StackPanel Grid.Row="10" Orientation="Horizontal">
            <Border Width="3" CornerRadius="2"
                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                    Margin="0,0,8,0" />
            <TextBlock Text="AI Provider" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </StackPanel>
        <ComboBox x:Name="ProviderCombo" Grid.Row="12"
                  SelectionChanged="ProviderCombo_SelectionChanged" />

        <!-- Model -->
        <StackPanel Grid.Row="14" Orientation="Horizontal">
            <Border Width="3" CornerRadius="2"
                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                    Margin="0,0,8,0" />
            <TextBlock Text="Model" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </StackPanel>
        <ComboBox x:Name="ModelCombo" Grid.Row="16" />

        <!-- API Key Fields (no longer overlapping!) -->
        <StackPanel Grid.Row="18">
            <StackPanel x:Name="StandardKeyField">
                <TextBlock Text="API Key" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4" />
                <ui:PasswordBox x:Name="ApiKeyBox" PlaceholderText="Enter your API key..." />
            </StackPanel>

            <StackPanel x:Name="CloudflareFields" Visibility="Collapsed">
                <TextBlock Text="Account ID" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,4" />
                <ui:TextBox x:Name="CloudflareAccountId" PlaceholderText="Cloudflare Account ID" />
                <TextBlock Text="API Token" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,8,0,4" />
                <ui:PasswordBox x:Name="CloudflareApiToken" PlaceholderText="Cloudflare API Token" />
            </StackPanel>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="20" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Skip" Appearance="Secondary" Click="SkipBtn_Click" Margin="0,0,8,0" />
            <ui:Button Appearance="Primary" Click="GetStartedBtn_Click">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Checkmark24" Margin="0,0,6,0" />
                    <TextBlock Text="Get Started" />
                </StackPanel>
            </ui:Button>
        </StackPanel>
    </Grid>
</Window>
