<Page x:Class="AcademicAI.App.Views.PlannerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:AcademicAI.App.Views"
      Title="Planner">
    <Page.Resources>
        <local:UrgencyTextConverter x:Key="UrgencyTextConverter" />
        <local:UrgencyBrushConverter x:Key="UrgencyBrushConverter" />
    </Page.Resources>
    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Add Assignment + Pomodoro -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Page Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <ui:SymbolIcon Symbol="CalendarMonth24" FontSize="24"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   Margin="0,0,10,0" VerticalAlignment="Center" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Title_Planner}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{DynamicResource Desc_Planner}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Add Assignment Card -->
                <ui:Card Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="3" CornerRadius="2"
                                    Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    Margin="0,0,10,0" />
                            <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="18"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,8,0" />
                            <TextBlock Text="{DynamicResource Lbl_AddAssignment}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Lbl_Title}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ui:TextBox PlaceholderText="Assignment title"
                                    Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Lbl_Subject}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ui:TextBox PlaceholderText="Subject"
                                    Text="{Binding NewSubject, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,12" />

                        <TextBlock Text="CATEGORY" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ComboBox SelectedValue="{Binding NewCategory}" SelectedValuePath="Tag"
                                  Margin="0,0,0,12">
                            <ComboBoxItem Content="{DynamicResource Category_Homework}" Tag="Homework" />
                            <ComboBoxItem Content="{DynamicResource Category_Exam}" Tag="Exam" />
                            <ComboBoxItem Content="{DynamicResource Category_Project}" Tag="Project" />
                            <ComboBoxItem Content="{DynamicResource Category_Reading}" Tag="Reading" />
                        </ComboBox>

                        <TextBlock Text="{DynamicResource Lbl_DueDate}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <DatePicker SelectedDate="{Binding NewDueDate}" Margin="0,0,0,12" />

                        <TextBlock Text="{DynamicResource Lbl_Priority}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ComboBox SelectedValue="{Binding NewPriority}" SelectedValuePath="Content"
                                  Margin="0,0,0,12">
                            <ComboBoxItem Content="High" />
                            <ComboBoxItem Content="Medium" />
                            <ComboBoxItem Content="Low" />
                        </ComboBox>

                        <TextBlock Text="{DynamicResource Lbl_Notes}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ui:TextBox PlaceholderText="Notes (optional)"
                                    Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,20" />

                        <ui:Button Appearance="Primary" Command="{Binding AddAssignmentCommand}"
                                   HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DocumentAdd24" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Btn_Add}" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </ui:Card>

                <!-- Pomodoro Card -->
                <ui:Card Padding="24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="3" CornerRadius="2"
                                    Background="{DynamicResource SystemFillColorSuccessBrush}"
                                    Margin="0,0,10,0" />
                            <ui:SymbolIcon Symbol="Clock24" FontSize="18"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,8,0" />
                            <TextBlock Text="{DynamicResource Lbl_PomodoroTimer}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{Binding TimerDisplay}"
                                   FontSize="48" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4" />

                        <TextBlock Text="{Binding CompletedSessions, StringFormat='{}{0} sessions completed'}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4" />

                        <TextBlock FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🎯 Focus Mode" />
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBreak}" Value="True">
                                            <Setter Property="Text" Value="☕ Break" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <ui:Button Appearance="Primary"
                                       Command="{Binding StartPlannerTimerCommand}">Start</ui:Button>
                            <ui:Button Appearance="Secondary"
                                       Command="{Binding PausePlannerTimerCommand}"
                                       Margin="8,0,0,0">Pause</ui:Button>
                            <ui:Button Appearance="Secondary"
                                       Command="{Binding SkipPlannerTimerCommand}"
                                       Margin="8,0,0,0">Skip</ui:Button>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT: Assignments List -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Header row with count badge and Clear Completed -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <TextBlock Text="{DynamicResource Lbl_Assignments}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <Border CornerRadius="10" Padding="8,2"
                                Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FilteredAssignments.Count}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>
                    <ui:Button Grid.Column="1" Appearance="Secondary"
                               Command="{Binding ClearCompletedCommand}"
                               VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Checkmark24" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Btn_ClearCompleted}" />
                        </StackPanel>
                    </ui:Button>
                </Grid>

                <!-- Filter + Sort -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{DynamicResource Lbl_Filter}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,4" />
                        <ComboBox SelectedValue="{Binding FilterCategory}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="{DynamicResource Filter_All}" Tag="All" />
                            <ComboBoxItem Content="{DynamicResource Category_Homework}" Tag="Homework" />
                            <ComboBoxItem Content="{DynamicResource Category_Exam}" Tag="Exam" />
                            <ComboBoxItem Content="{DynamicResource Category_Project}" Tag="Project" />
                            <ComboBoxItem Content="{DynamicResource Category_Reading}" Tag="Reading" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Lbl_SortBy}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,4" />
                        <ComboBox SelectedValue="{Binding SortBy}" SelectedValuePath="Tag">
                            <ComboBoxItem Content="{DynamicResource Sort_DueDate}" Tag="DueDate" />
                            <ComboBoxItem Content="Priority" Tag="Priority" />
                            <ComboBoxItem Content="Subject" Tag="Subject" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <!-- Assignment Cards -->
                <ItemsControl ItemsSource="{Binding FilteredAssignments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Padding="16" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Priority badge -->
                                    <Border Grid.Column="0" CornerRadius="4" Padding="8,2"
                                            Margin="0,0,12,0" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Priority}" Value="High">
                                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Priority}" FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </Border>

                                    <!-- Details -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethrough}}">
                                                <TextBlock.Text>
                                                    <Binding Path="Title" />
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <Border Width="8" Height="8" CornerRadius="4"
                                                    Margin="6,0,0,0" VerticalAlignment="Center"
                                                    Background="{Binding Converter={StaticResource UrgencyBrushConverter}}" />
                                            <TextBlock Text="{Binding Converter={StaticResource UrgencyTextConverter}}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{Binding Converter={StaticResource UrgencyBrushConverter}}"
                                                       Margin="4,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                            <Run Text="{Binding Subject}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding DueDate, StringFormat='{}{0:MMM dd}'}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding Notes}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- Complete -->
                                    <ui:Button Grid.Column="2" Appearance="Transparent" Margin="4,0,0,0"
                                               VerticalAlignment="Center"
                                               Command="{Binding DataContext.CompleteAssignmentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" ToolTip="Mark Complete">
                                        <ui:SymbolIcon Symbol="Checkmark24" FontSize="16" />
                                    </ui:Button>

                                    <!-- Delete -->
                                    <ui:Button Grid.Column="3" Appearance="Transparent" Margin="4,0,0,0"
                                               VerticalAlignment="Center"
                                               Command="{Binding DataContext.DeleteAssignmentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" ToolTip="Delete">
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" />
                                    </ui:Button>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty State -->
                <StackPanel Visibility="{Binding HasAssignments, Converter={StaticResource InvertBoolToVis}}"
                            HorizontalAlignment="Center" Margin="0,48,0,0">
                    <ui:SymbolIcon Symbol="CalendarMonth24" FontSize="48"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" />
                    <TextBlock Text="{DynamicResource Msg_NoAssignments}"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
