<Page x:Class="AcademicAI.App.Views.GrammarCheckView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Grammar Checker">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32">
            <TextBlock Text="Grammar Checker" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,16" />
            <ui:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Checkmark24" FontSize="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="Input" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <ui:TextBox PlaceholderText="Paste text to check for grammar errors..." Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                                VerticalScrollBarVisibility="Auto" Margin="0,0,0,16" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Appearance="Primary" Command="{Binding CheckGrammarCommand}"
                                   IsEnabled="{Binding IsProcessing, Converter={StaticResource BoolNegate}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Checkmark24" Margin="0,0,8,0" />
                                <TextBlock Text="Check Grammar" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Secondary" Command="{Binding CancelCommand}"
                                   Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                                   Margin="8,0,0,0" Content="Cancel" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" Margin="0,8,0,0">
                        <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0" />
                        <TextBlock Text="Checking grammar..." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>
            <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       Margin="0,0,0,8" Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />
            <ui:Card Padding="20" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Checkmark24" FontSize="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="Corrections" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Background="{DynamicResource ApplicationBackgroundBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <TextBox Text="{Binding ResultText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True"
                                 TextWrapping="Wrap" MinHeight="120" Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontSize="13" />
                    </Border>
                    <ui:Button Appearance="Secondary" Command="{Binding CopyResultCommand}" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Copy24" Margin="0,0,6,0" />
                            <TextBlock Text="Copy" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
