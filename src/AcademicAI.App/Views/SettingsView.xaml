<Page x:Class="AcademicAI.App.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:AcademicAI.App.Views"
      Title="Settings">
    <Page.Resources>
        <local:ConfiguredBrushConverter x:Key="ConfiguredBrushConverter" />
        <local:ConfiguredTextConverter x:Key="ConfiguredTextConverter" />
        <local:StringVisibilityConverter x:Key="StringVisibilityConverter" />
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28">

            <!-- Page Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <ui:SymbolIcon Symbol="Settings24" FontSize="28"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Title_Settings}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="{DynamicResource Desc_Settings}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- ── Language & Theme ──────────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="3" CornerRadius="2"
                        Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Margin="0,0,10,0" />
                <ui:SymbolIcon Symbol="Globe24" FontSize="18"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,8,0" />
                <TextBlock Text="{DynamicResource Lbl_LanguageTheme}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <ui:Card Margin="0,0,0,20">
                <StackPanel Margin="20">
                    <TextBlock Text="{DynamicResource Settings_Language}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="LanguageComboBox" Width="240" HorizontalAlignment="Left"
                              SelectedValue="{Binding SelectedLanguage}" SelectedValuePath="Tag"
                              SelectionChanged="LanguageComboBox_SelectionChanged" Margin="0,0,0,16">
                        <ComboBoxItem Content="🇬🇧  English" Tag="en" />
                        <ComboBoxItem Content="🇸🇦  العربية" Tag="ar" />
                        <ComboBoxItem Content="🇫🇷  Français" Tag="fr" />
                        <ComboBoxItem Content="🇪🇸  Español" Tag="es" />
                        <ComboBoxItem Content="🇩🇪  Deutsch" Tag="de" />
                    </ComboBox>

                    <TextBlock Text="{DynamicResource Settings_Theme}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button x:Name="DarkThemeButton" Appearance="Primary" Margin="0,0,8,0"
                                   Click="DarkThemeButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="WeatherMoon24" Margin="0,0,6,0" />
                                <TextBlock Text="Dark" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button x:Name="LightThemeButton" Appearance="Secondary"
                                   Click="LightThemeButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="WeatherSunny24" Margin="0,0,6,0" />
                                <TextBlock Text="Light" />
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- ── General ───────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="3" CornerRadius="2"
                        Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Margin="0,0,10,0" />
                <ui:SymbolIcon Symbol="Options24" FontSize="18"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,8,0" />
                <TextBlock Text="{DynamicResource Lbl_General}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <ui:Card Margin="0,0,0,20">
                <StackPanel Margin="20">
                    <ui:CardControl Margin="0,0,0,8">
                        <ui:CardControl.Header>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings_MinimizeToTray}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="{DynamicResource Desc_MinimizeToTray}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding MinimizeToTray}" />
                    </ui:CardControl>
                    <ui:CardControl>
                        <ui:CardControl.Header>
                            <StackPanel>
                                 <TextBlock Text="{DynamicResource Settings_ClipboardMonitor}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="{DynamicResource Desc_ClipboardMonitor}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </ui:CardControl.Header>
                        <ui:ToggleSwitch IsChecked="{Binding ClipboardMonitorEnabled}" />
                    </ui:CardControl>
                </StackPanel>
            </ui:Card>

            <!-- ── Default AI Providers ───────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="3" CornerRadius="2"
                        Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Margin="0,0,10,0" />
                <ui:SymbolIcon Symbol="Bot24" FontSize="18"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,8,0" />
                <TextBlock Text="{DynamicResource Settings_DefaultProviders}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <ui:Card Margin="0,0,0,20">
                <StackPanel Margin="20">
                    <TextBlock Text="{DynamicResource Desc_DefaultProviders}"
                               FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16" />
                    <ItemsControl ItemsSource="{Binding FeatureDefaultItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Feature}" FontSize="13"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableProviders}"
                                              SelectedItem="{Binding Provider}" Margin="0,0,8,0" />
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableModels}"
                                              SelectedItem="{Binding Model}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ui:Button Appearance="Primary" Margin="0,12,0,0" HorizontalAlignment="Left"
                               Command="{Binding SaveFeatureDefaultsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save24" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Btn_SaveDefaults}" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

            <!-- ── API Keys ───────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="3" CornerRadius="2"
                        Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Margin="0,0,10,0" />
                <ui:SymbolIcon Symbol="Key24" FontSize="18"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,8,0" />
                <TextBlock Text="{DynamicResource Lbl_ApiKeys}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <ui:Card Margin="0,0,0,20" Padding="24">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Desc_ApiKeys}"
                               FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16" />

                    <ItemsControl ItemsSource="{Binding ProviderConfigItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:CardExpander Margin="0,0,0,10">
                                    <ui:CardExpander.Header>
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Margin="0,0,10,0"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Symbol" Value="Server24" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ProviderName}" Value="OpenRouter">
                                                                <Setter Property="Symbol" Value="Globe24" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ProviderName}" Value="Fireworks">
                                                                <Setter Property="Symbol" Value="Fire24" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                            <TextBlock Grid.Column="1" Text="{Binding ProviderName}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Column="2" CornerRadius="4" Padding="8,3"
                                                    Background="{Binding IsConfigured, Converter={StaticResource ConfiguredBrushConverter}}">
                                                <TextBlock Text="{Binding IsConfigured, Converter={StaticResource ConfiguredTextConverter}}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ApplicationBackgroundBrush}" />
                                            </Border>
                                        </Grid>
                                    </ui:CardExpander.Header>
                                    <StackPanel Margin="4,8,4,4">
                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,16" />

                                        <TextBlock Text="{DynamicResource Lbl_ApiKey}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,6" />
                                        <ui:PasswordBox Password="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                        PasswordChanged="ApiKeyBox_PasswordChanged"
                                                        PlaceholderText="Enter API key..."
                                                        Margin="0,0,0,8" />

                                        <TextBlock Text="{Binding TestResult}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,8"
                                                   Visibility="{Binding TestResult, Converter={StaticResource StringVisibilityConverter}}" />

                                        <StackPanel Orientation="Horizontal">
                                            <ui:Button Appearance="Primary" Margin="0,0,8,0"
                                                       Command="{Binding DataContext.SaveProviderKeyCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Save24" Margin="0,0,6,0" />
                                                    <TextBlock Text="{DynamicResource Btn_SaveKey}" />
                                                </StackPanel>
                                            </ui:Button>
                                            <ui:Button Appearance="Secondary"
                                                       Command="{Binding DataContext.TestProviderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="PlugConnected24" Margin="0,0,6,0" />
                                                    <TextBlock Text="{DynamicResource Btn_TestConnection}" />
                                                </StackPanel>
                                            </ui:Button>
                                        </StackPanel>
                                    </StackPanel>
                                </ui:CardExpander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>

            <!-- ── Token Usage ────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="3" CornerRadius="2"
                        Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Margin="0,0,10,0" />
                <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="18"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,8,0" />
                <TextBlock Text="{DynamicResource Settings_TokenUsage}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <ui:Card Margin="0,0,0,20">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <ui:SymbolIcon Symbol="CallInbound24" FontSize="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4" />
                        <TextBlock Text="{DynamicResource Lbl_TotalCalls}" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding TotalCalls}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <ui:SymbolIcon Symbol="Tag24" FontSize="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4" />
                        <TextBlock Text="{DynamicResource Lbl_TotalTokens}" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding TotalTokens}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <ui:SymbolIcon Symbol="Money24" FontSize="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,4" />
                        <TextBlock Text="{DynamicResource Lbl_EstCost}" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding EstimatedCost}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- ── License & Info ─────────────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Width="3" CornerRadius="2"
                        Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Margin="0,0,10,0" />
                <ui:SymbolIcon Symbol="Shield24" FontSize="18"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,8,0" />
                <TextBlock Text="{DynamicResource Lbl_LicenseInfo}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <ui:Card Margin="0,0,0,16">
                <StackPanel Margin="20">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource Settings_LicenseKey}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding MaskedLicenseKey}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <ui:Button Grid.Column="2" Appearance="Transparent"
                                   Command="{Binding CopyLicenseCommand}" ToolTip="Copy">
                            <ui:SymbolIcon Symbol="Copy24" />
                        </ui:Button>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource Settings_Version}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding AppVersion}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource Lbl_LastUpdateCheck}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding LastUpdateCheck}" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>
                    <ui:Button Appearance="Secondary" HorizontalAlignment="Left"
                               Command="{Binding CheckForUpdatesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource Btn_CheckUpdates}" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
