<Page x:Class="AcademicAI.App.Views.StudyHubView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Study Hub">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <ui:SymbolIcon Symbol="HatGraduation24" FontSize="28"
                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                           Margin="0,0,12,0" VerticalAlignment="Center" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Study Hub" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Flashcards, quizzes, notes, and math tools"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- Tab Strip with Icons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:Button x:Name="Tab0Btn" Appearance="Primary" Click="SelectTab0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Flash24" FontSize="16" Margin="0,0,6,0" />
                    <TextBlock Text="Flashcards" />
                </StackPanel>
            </ui:Button>
            <ui:Button x:Name="Tab1Btn" Appearance="Secondary" Click="SelectTab1" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="QuestionCircle24" FontSize="16" Margin="0,0,6,0" />
                    <TextBlock Text="Quiz" />
                </StackPanel>
            </ui:Button>
            <ui:Button x:Name="Tab2Btn" Appearance="Secondary" Click="SelectTab2" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Notebook24" FontSize="16" Margin="0,0,6,0" />
                    <TextBlock Text="Notes" />
                </StackPanel>
            </ui:Button>
            <ui:Button x:Name="Tab3Btn" Appearance="Secondary" Click="SelectTab3" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Calculator24" FontSize="16" Margin="0,0,6,0" />
                    <TextBlock Text="Math" />
                </StackPanel>
            </ui:Button>
        </StackPanel>

        <Frame x:Name="TabContent" Grid.Row="2" NavigationUIVisibility="Hidden" JournalOwnership="OwnsJournal" />
    </Grid>
</Page>
