<Page x:Class="AcademicAI.App.Views.DetectorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:AcademicAI.App.Controls"
      xmlns:local="clr-namespace:AcademicAI.App.Views"
      Title="AI Detector">
    <Page.Resources>
        <local:ProbabilityBrushConverter x:Key="ProbabilityBrushConverter" />
        <local:StringVisibilityConverter x:Key="StringVisibilityConverter" />
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28">

            <!-- Page Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="28"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="AI Content Detector"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Analyze text to detect AI-generated content"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Input Card -->
            <ui:Card Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2"
                                Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="Input"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="PDF INPUT" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,6" />
                    <controls:PdfDropZone x:Name="PdfDrop" Height="80" Margin="0,0,0,12" />

                    <TextBlock Text="— or paste text below —" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,10" />

                    <ui:TextBox Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Paste text to analyze..."
                                AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                                Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Appearance="Primary"
                                   Command="{Binding DetectCommand}"
                                   IsEnabled="{Binding IsDetecting, Converter={StaticResource BoolNegate}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ShieldCheckmark24" Margin="0,0,8,0" />
                                <TextBlock Text="Analyze" />
                            </StackPanel>
                        </ui:Button>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsDetecting, Converter={StaticResource BoolToVis}}"
                                    Margin="16,0,0,0">
                            <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0" />
                            <TextBlock Text="Analyzing..." FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       FontSize="12" Margin="0,0,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringVisibilityConverter}}" />

            <!-- Result Card -->
            <ui:Card Padding="28"
                     Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"
                     Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Width="3" CornerRadius="2"
                                Background="{Binding AiProbability, Converter={StaticResource ProbabilityBrushConverter}}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="Detection Result"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Circular gauge area -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Score Display -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <Border Width="140" Height="140" CornerRadius="70"
                                    BorderThickness="6"
                                    BorderBrush="{Binding AiProbability, Converter={StaticResource ProbabilityBrushConverter}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding AiProbability, StringFormat='{}{0:F0}%'}"
                                               FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{Binding AiProbability, Converter={StaticResource ProbabilityBrushConverter}}" />
                                    <TextBlock Text="AI Probability"
                                               FontSize="10" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="{Binding DetectionLevel}" FontSize="16"
                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                       Foreground="{Binding AiProbability, Converter={StaticResource ProbabilityBrushConverter}}"
                                       Margin="0,12,0,0" />
                        </StackPanel>

                        <!-- Reasoning -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Analysis" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,8" />
                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    CornerRadius="8" Padding="16">
                                <TextBlock Text="{Binding DetectionReasoning}" FontSize="13" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           MaxWidth="400" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Probability Bar -->
                    <ProgressBar Value="{Binding AiProbability, Mode=OneWay}"
                                 Maximum="100" Height="6" Margin="0,0,0,16" />

                    <!-- Copy Button -->
                    <ui:Button Appearance="Secondary" HorizontalAlignment="Right"
                               Command="{Binding CopyResultCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Copy24" Margin="0,0,6,0" />
                            <TextBlock Text="Copy Result" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

            <!-- Empty State -->
            <ui:Card Visibility="{Binding HasResult, Converter={StaticResource InvertBoolToVis}}"
                     Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Center" Margin="32">
                    <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="48"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="Paste text or drop a PDF to detect AI-generated content"
                               FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
