<Page x:Class="AcademicAI.App.Views.QuizView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Quiz Generator">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32">
            <TextBlock Text="Quiz Generator" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,16" />
            <ui:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Clipboard24" FontSize="20"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" />
                        <TextBlock Text="Input" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <ui:TextBox PlaceholderText="Enter a topic for the quiz..." Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                                VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Question Count" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                            <ui:TextBox Text="{Binding QuestionCount}" InputScope="Number" MinWidth="80" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Quiz Type" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding AvailableQuizTypes}" SelectedItem="{Binding QuizType}" MinWidth="120" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Appearance="Primary" Command="{Binding GenerateQuizCommand}"
                                   IsEnabled="{Binding IsProcessing, Converter={StaticResource BoolNegate}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Clipboard24" Margin="0,0,8,0" />
                                <TextBlock Text="Generate Quiz" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Secondary" Command="{Binding CancelCommand}"
                                   Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                                   Margin="8,0,0,0" Content="Cancel" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" Margin="0,8,0,0">
                        <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0" />
                        <TextBlock Text="Generating quiz..." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       Margin="0,0,0,8" Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />

            <!-- Interactive Quiz Questions -->
            <StackPanel x:Name="QuizContainer"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Width="3" CornerRadius="2"
                            Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            Margin="0,0,10,0" />
                    <ui:SymbolIcon Symbol="Clipboard24" FontSize="20"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" />
                    <TextBlock Text="Quiz" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Name="ScoreLabel" FontSize="12" Margin="12,0,0,0"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <ItemsControl x:Name="QuizQuestionsList" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
