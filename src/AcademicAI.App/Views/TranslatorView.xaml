<Page x:Class="AcademicAI.App.Views.TranslatorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Translator">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28">

            <!-- Page Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="Translate24" FontSize="28"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Translator" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="Translate text between languages with AI precision"
                               FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Language Selector Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="SOURCE LANGUAGE" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding SourceLanguage}" />
                    </StackPanel>
                </ui:Card>

                <!-- Swap Button — centred, large -->
                <ui:Button Grid.Column="1" Appearance="Secondary"
                           Command="{Binding SwapLanguagesCommand}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Width="44" Height="44">
                    <ui:SymbolIcon Symbol="ArrowSwap24" FontSize="20" />
                </ui:Button>

                <ui:Card Grid.Column="2" Padding="20">
                    <StackPanel>
                        <TextBlock Text="TARGET LANGUAGE" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding TargetLanguage}" />
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- Input Card -->
            <ui:Card Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2"
                                Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="Input" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <ui:TextBox x:Name="InputBox"
                                PlaceholderText="Enter text to translate..."
                                Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True" TextWrapping="Wrap"
                                MinHeight="130"
                                VerticalScrollBarVisibility="Auto"
                                Margin="0,0,0,4"
                                TextChanged="InputBox_TextChanged" />
                    <TextBlock x:Name="CharCountLabel" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </ui:Card>

            <!-- Translate Button -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <ui:Button Appearance="Primary"
                           Command="{Binding TranslateCommand}"
                           IsEnabled="{Binding IsTranslating, Converter={StaticResource BoolNegate}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Translate24" Margin="0,0,8,0" />
                        <TextBlock Text="Translate" />
                    </StackPanel>
                </ui:Button>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IsTranslating, Converter={StaticResource BoolToVis}}"
                            Margin="16,0,0,0">
                    <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0" />
                    <TextBlock Text="Translating..." FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       Margin="0,0,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />

            <!-- Result Card -->
            <ui:Card Padding="24" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2"
                                Background="{DynamicResource SystemFillColorSuccessBrush}"
                                Margin="0,0,10,0" />
                        <ui:SymbolIcon Symbol="Translate24" FontSize="18"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,8,0" />
                        <TextBlock Text="Translation" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <TextBox Text="{Binding TranslatedText, Mode=OneWay}"
                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 FontSize="13" />
                    </Border>

                    <ui:Button Appearance="Secondary" HorizontalAlignment="Right"
                               Command="{Binding CopyResultCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Copy24" Margin="0,0,6,0" />
                            <TextBlock Text="Copy" />
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</Page>
