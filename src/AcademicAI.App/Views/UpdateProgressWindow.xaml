<Window x:Class="AcademicAI.App.Views.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Updating AcademicAI Suite"
        Width="400" Height="140"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="VersionText" Grid.Row="0" Text="{DynamicResource Msg_DownloadingUpdate}"
                   FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

        <ProgressBar x:Name="ProgressBar" Grid.Row="2" Value="0" IsIndeterminate="False" />

        <TextBlock x:Name="PercentText" Grid.Row="4" Text="0%"
                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
    </Grid>
</Window>
