<Page x:Class="AcademicAI.App.Views.WriterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:AcademicAI.App.Views"
      Title="Writer">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,16">
            <ui:Button x:Name="Tab0Btn" Appearance="Primary" Content="{DynamicResource Nav_AcademicWriter}" Click="SelectTab0" />
            <ui:Button x:Name="Tab1Btn" Appearance="Secondary" Content="{DynamicResource Nav_EssayOutline}" Click="SelectTab1" Margin="8,0,0,0" />
            <ui:Button x:Name="Tab2Btn" Appearance="Secondary" Content="{DynamicResource Nav_GrammarCheck}" Click="SelectTab2" Margin="8,0,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <local:AcademicWriterView x:Name="Tab0Content" Visibility="Visible" />
            <local:EssayOutlineView x:Name="Tab1Content" Visibility="Collapsed" />
            <local:GrammarCheckView x:Name="Tab2Content" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
