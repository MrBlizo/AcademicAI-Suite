<UserControl x:Class="AcademicAI.App.Views.ResearchLibraryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28">

            <!-- Page Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="Book24" FontSize="28"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Title_ResearchLibrary}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="{DynamicResource Desc_ResearchLibrary}"
                               FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Search Card -->
            <ui:Card Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox PlaceholderText="Search books, papers, articles..."
                                    Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                    Grid.Column="0" Margin="0,0,12,0" />
                        <ui:Button Appearance="Primary" Grid.Column="1"
                                   Command="{Binding SearchCommand}"
                                   IsEnabled="{Binding IsSearching, Converter={StaticResource BoolNegate}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Search24" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource Btn_Search}" />
                            </StackPanel>
                        </ui:Button>
                    </Grid>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"
                                Margin="0,10,0,0">
                        <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Quick Access Sources -->
            <ui:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="3" CornerRadius="2"
                                Background="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Margin="0,0,10,0" />
                        <TextBlock Text="{DynamicResource Lbl_BrowseSources}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <WrapPanel>
                        <ui:Button Appearance="Secondary" Margin="0,0,8,8"
                                   Click="OpenSciHub" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="4"
                                        Background="#266366F1" Margin="0,0,8,0">
                                    <ui:SymbolIcon Symbol="DocumentSearch24" FontSize="12"
                                                   Foreground="#818CF8"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{DynamicResource Src_SciHubArticles}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Secondary" Margin="0,0,8,8"
                                   Click="OpenZLib" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="4"
                                        Background="#2610B981" Margin="0,0,8,0">
                                    <ui:SymbolIcon Symbol="Book24" FontSize="12"
                                                   Foreground="#34D399"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{DynamicResource Src_ZLibrary}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Secondary" Margin="0,0,8,8"
                                   Click="OpenAnnasArchive" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="4"
                                        Background="#26F59E0B" Margin="0,0,8,0">
                                    <ui:SymbolIcon Symbol="Library24" FontSize="12"
                                                   Foreground="#FBBF24"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{DynamicResource Src_AnnasArchive}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Secondary" Margin="0,0,8,8"
                                   Click="OpenLibGen" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="4"
                                        Background="#26EC4899" Margin="0,0,8,0">
                                    <ui:SymbolIcon Symbol="BookOpen24" FontSize="12"
                                                   Foreground="#F472B6"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{DynamicResource Src_LibraryGenesis}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </WrapPanel>
                </StackPanel>
            </ui:Card>

            <!-- Status message after search -->
            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,8"
                       Visibility="{Binding HasSearched, Converter={StaticResource BoolToVis}}" />

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       Margin="0,0,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />

            <!-- Results -->
            <Grid>
                <ItemsControl ItemsSource="{Binding Results}"
                              Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Padding="24" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Source Badge + Title -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                Background="#266366F1">
                                            <TextBlock Text="{Binding Source}" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#818CF8" />
                                        </Border>
                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                Background="#2610B981"
                                                Visibility="{Binding FileType, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding FileType}" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#34D399" />
                                        </Border>
                                        <Border CornerRadius="4" Padding="6,2"
                                                Background="#26F59E0B"
                                                Visibility="{Binding FileSize, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding FileSize}" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#FBBF24" />
                                        </Border>
                                    </StackPanel>

                                    <!-- Title -->
                                    <TextBlock Grid.Row="1" Text="{Binding Title}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               TextWrapping="Wrap" />

                                    <!-- Authors + Year -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0"
                                                Visibility="{Binding Authors, Converter={StaticResource BoolToVis}}">
                                        <ui:SymbolIcon Symbol="Person24" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,4,0" />
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                            <Run Text="{Binding Authors}" />
                                            <Run Text="{Binding Year, StringFormat=' ({0})'}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Abstract/Info -->
                                    <TextBlock Grid.Row="3" Text="{Binding Abstract}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               TextWrapping="Wrap" MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,6,0,10" />

                                    <!-- Actions -->
                                    <WrapPanel Grid.Row="4">
                                        <ui:Button Appearance="Primary" Margin="0,0,8,4"
                                                   Click="OpenUrl" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Open24" Margin="0,0,6,0" />
                                                <TextBlock Text="{DynamicResource Btn_ViewDownload}" />
                                            </StackPanel>
                                        </ui:Button>
                                        <ui:Button Appearance="Secondary" Margin="0,0,8,4"
                                                   Command="{Binding DataContext.CopyCitationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Copy24" Margin="0,0,6,0" />
                                                <TextBlock Text="{DynamicResource Btn_CopyCitation}" />
                                            </StackPanel>
                                        </ui:Button>
                                        <ui:Button Appearance="Secondary" Margin="0,0,8,4"
                                                   Click="SearchOnSciHub" Tag="{Binding Title}">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="16" Height="16" CornerRadius="3"
                                                        Background="#266366F1" Margin="0,0,6,0">
                                                    <ui:SymbolIcon Symbol="DocumentSearch24" FontSize="9"
                                                                   Foreground="#818CF8"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="{DynamicResource Src_SciHub}" />
                                            </StackPanel>
                                        </ui:Button>
                                        <ui:Button Appearance="Secondary" Margin="0,0,8,4"
                                                   Click="SearchOnZLib" Tag="{Binding Title}">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="16" Height="16" CornerRadius="3"
                                                        Background="#2610B981" Margin="0,0,6,0">
                                                    <ui:SymbolIcon Symbol="Book24" FontSize="9"
                                                                   Foreground="#34D399"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Text="{DynamicResource Src_ZLib}" />
                                            </StackPanel>
                                        </ui:Button>
                                    </WrapPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty / No Results State -->
                <StackPanel Visibility="{Binding HasResults, Converter={StaticResource InvertBoolToVis}}"
                            HorizontalAlignment="Center" Margin="0,64,0,0">
                    <ui:SymbolIcon Symbol="BookSearch24" FontSize="52"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center" />
                    <TextBlock FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{DynamicResource Msg_SearchPrompt}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSearched}" Value="True">
                                        <Setter Property="Text" Value="{DynamicResource Msg_NoResults}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock FontSize="12" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{DynamicResource Msg_ResultsSource}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSearched}" Value="True">
                                        <Setter Property="Text" Value="{DynamicResource Msg_TryDifferentQuery}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
