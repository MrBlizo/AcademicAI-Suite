<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  AcademicAI 2026 Design System                              ║
    ║  Palette: Deep Indigo · Electric Violet · Midnight Teal     ║
    ║  Feel: Chill · Modern · Premium Dark                        ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <!-- ── Core Accent Colours ── -->
    <!-- Primary gradient: indigo → violet -->
    <Color x:Key="AccentPrimaryColor">#6366F1</Color>
    <Color x:Key="AccentSecondaryColor">#8B5CF6</Color>
    <Color x:Key="AccentTertiaryColor">#A78BFA</Color>
    <Color x:Key="AccentTealColor">#14B8A6</Color>
    <Color x:Key="AccentPinkColor">#EC4899</Color>

    <SolidColorBrush x:Key="AiAccentBrush" Color="#6366F1" />
    <SolidColorBrush x:Key="AiAccentVioletBrush" Color="#8B5CF6" />
    <SolidColorBrush x:Key="AiAccentTealBrush" Color="#14B8A6" />
    <SolidColorBrush x:Key="AiAccentPinkBrush" Color="#EC4899" />

    <!-- Gradient brushes for cards and highlights -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#6366F1" Offset="0" />
        <GradientStop Color="#8B5CF6" Offset="0.5" />
        <GradientStop Color="#A78BFA" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientVerticalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#6366F1" Offset="0" />
        <GradientStop Color="#4F46E5" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TealToVioletGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#14B8A6" Offset="0" />
        <GradientStop Color="#6366F1" Offset="1" />
    </LinearGradientBrush>

    <!-- Glass-effect overlay for cards (very low opacity white) -->
    <SolidColorBrush x:Key="GlassSurfaceBrush" Color="#0DFFFFFF" />
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#1AFFFFFF" />

    <!-- Stat card per-category tint brushes -->
    <SolidColorBrush x:Key="StatAccentIndigoBrush" Color="#6366F1" Opacity="0.18" />
    <SolidColorBrush x:Key="StatAccentGreenBrush" Color="#10B981" />
    <SolidColorBrush x:Key="StatAccentRedBrush" Color="#F87171" />

    <!-- ── Typography ── -->
    <FontFamily x:Key="AppFont">Segoe UI Variable Display, Segoe UI, sans-serif</FontFamily>

    <!-- ── Reusable Section Header with accent left-border ── -->
    <Style x:Key="SectionDivider" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- ── Accent Left Border (3px pill) ── -->
    <Style x:Key="AccentPill" TargetType="Border">
        <Setter Property="Width" Value="3" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="{StaticResource AiAccentBrush}" />
        <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <!-- ── Section Header Text ── -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Secondary Label ── -->
    <Style x:Key="SecondaryLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- ── Hint / Tertiary Label ── -->
    <Style x:Key="HintLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
    </Style>

    <!-- ── Stat Badge Number ── -->
    <Style x:Key="StatNumber" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <!-- ── Gradient accent top bar (for splash + header) ── -->
    <Style x:Key="AccentTopBar" TargetType="Border">
        <Setter Property="Height" Value="4" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
    </Style>

    <!-- ── Icon Badge Container ── -->
    <Style x:Key="IconBadge" TargetType="Border">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Opacity" Value="0.15" />
        <Setter Property="Margin" Value="0,0,12,0" />
    </Style>

    <!-- ── Count / Status Pill ── -->
    <Style x:Key="CountPill" TargetType="Border">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="Background" Value="{StaticResource AiAccentBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="10,0,0,0" />
    </Style>

    <!-- ── Hyperlink-style TextBlock (for research titles) ── -->
    <Style x:Key="HyperlinkText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AiAccentBrush}" />
        <Setter Property="TextDecorations" Value="Underline" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Opacity" Value="0.85" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

</ResourceDictionary>
