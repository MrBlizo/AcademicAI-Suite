<UserControl x:Class="AcademicAI.App.Controls.PdfDropZone"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             AllowDrop="True"
             DragOver="PdfDropZone_DragOver"
             Drop="PdfDropZone_Drop">
    <Border x:Name="DropBorder" CornerRadius="12" Padding="28,20"
            Background="#1E1E2E"
            BorderThickness="2"
            BorderBrush="#6366F1">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="28"
                           Foreground="#A5B4FC"
                           HorizontalAlignment="Center" Margin="0,0,0,10" />
            <TextBlock Text="Drop PDF here or click to browse"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Supports .pdf files"
                       FontSize="11"
                       Foreground="#9CA3AF"
                       HorizontalAlignment="Center" Margin="0,4,0,0" />
            <TextBlock x:Name="FileNameText" Text=""
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="#A5B4FC"
                       HorizontalAlignment="Center" Margin="0,8,0,0" />
        </StackPanel>
    </Border>
</UserControl>
